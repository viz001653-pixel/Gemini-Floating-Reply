{
  "manifest_version": 3,
  "name": "Gemini Floating Reply",
  "version": "1.0.0",
  "description": "Select any text in Gemini and quote-reply it to the input box, just like Claude & ChatGPT.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://gemini.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Floating Reply"
  }
}
